<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
	<!-- Updated to use local SQLEXPRESS instance. Use Integrated Security for developer machine.
		 Change to SQL authentication (User ID/Password) if needed. -->
	<add name="QL_FASTFOOD"
      connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=QL_FASTFOOD;Integrated Security=True;Persist Security Info=False;Pooling=False;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=True"
		 providerName="System.Data.SqlClient" />
  </connectionStrings>
</configuration>
